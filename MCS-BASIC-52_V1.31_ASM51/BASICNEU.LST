                    6121    ;
                    6122    ;*****************************************************************************
                    6123    ;****** Sorry - but the ego message had to be disabled ***********************
                    6124    ;
                    6125    ;WB:
                    6126    ;
                    6127    ;       DB      'W'+80H,'R'+80H
