                     285            ;***************************************************************
                     286            ;
001B C0D0            287            PUSH    PSW
001D 021F78          288            LJMP    CKS_I
                     289            ;
0020 021902          290    STJ:    LJMP    I_DR            ;DO THE INTERRUPT
