  001D               411    INBIT           BIT     29      ;35.5-INITIALIZATION BIT
  001E               412    CIUB            BIT     30      ;35.6-USER CONSOLE IN BIT
                     413                                    ;     0 = SERIAL PORT
                     414                                    ;     1 = USER ROUTINE
  001F               415    SPINT           BIT     31      ;35.7-SERIAL PORT INTERRUPT
  0020               416    STOPBIT         BIT     32      ;36.0-PROGRAM STOP ENCOUNTERED
