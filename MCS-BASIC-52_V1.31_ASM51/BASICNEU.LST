0002 37              240            ADDC    A,@R1
                     241            ;
0003                 242            ORG     3H
                     243            ;
                     244            ;***************************************************************
                     245            ;
                     246            ;EXTERNAL INTERRUPT 0
                     247            ;
                     248            ;***************************************************************
                     249            ;
0003 20312D          250            JB      DRQ,STQ         ;SEE IF DMA IS SET
0006 C0D0            251            PUSH    PSW             ;SAVE THE STATUS
0008 024003          252            LJMP    4003H           ;JUMP TO USER IF NOT SET
                     253            ;
000B                 254            ORG     0BH
                     255            ;
                     256            ;***************************************************************
                     257            ;
                     258            ;TIMER 0 OVERFLOW INTERRUPT
                     259            ;
                     260            ;***************************************************************
                     261            ;
