                     193            ; TRAP VECTORS TO MONITOR
                     194            ;
                     195            ; RESET TAG (0AAH) ---------2001H
                     196            ;
                     197            ; TAG LOCATION (5AH) ------ 2002H
                     198            ;
                     199            ; EXTERNAL INTERRUPT 0 ---- 2040H
                     200            ;
                     201            ; COMMAND MODE ENTRY ------ 2048H
                     202            ;
                     203            ; SERIAL PORT ------------- 2050H
                     204            ;
                     205            ; MONITOR (BUBBLE) OUTPUT - 2058H
                     206            ;
                     207            ; MONITOR (BUBBLE) INPUT -- 2060H
                     208            ;
                     209            ; MONITOR (BUBBLE) CSTS --- 2068H
                     210            ;
                     211            ; GET USER JUMP VECTOR ---- 2070H
                     212            ;
                     213            ; GET USER LOOKUP VECTOR -- 2078H
                     214            ;
                     215            ; PRINT AT VECTOR --------- 2080H
                     216            ;
                     217            ; INTERRUPT PWM ----------- 2088H
                     218            ;
                     219            ; EXTERNAL RESET ---------- 2090H
                     220            ;
                     221            ; USER OUTPUT-------------- 4030H
                     222            ;
                     223            ; USER INPUT -------------- 4033H
                     224            ;
                     225            ; USER CSTS --------------- 4036H
                     226            ;
                     227            ; USER RESET -------------- 4039H
                     228            ;
                     229            ; USER DEFINED PRINT @ ---  403CH
                     230            ;
                     231            ;***************************************************************
                     232            ;
