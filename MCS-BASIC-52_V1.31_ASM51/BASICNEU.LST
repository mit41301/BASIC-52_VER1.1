                    4170            ;
                    4171            ;**************************************************************
                    4172            ;
                    4173            ; This table contains all of the floating point constants
                    4174            ;
                    4175            ; The constants in ROM are stored "backwards" from the way
                    4176            ; basic normally treats floating point numbers. Instead of
                    4177            ; loading from the exponent and decrementing the pointer,
                    4178            ; ROM constants pointers load from the most significant
                    4179            ; digits and increment the pointers. This is done to 1) make
                    4180            ; arg stack loading faster and 2) compensate for the fact that
                    4181            ; no decrement data pointer instruction exsist.
                    4182            ;
                    4183            ; The numbers are stored as follows:
                    4184            ;
                    4185            ; BYTE X+5    = MOST SIGNIFICANT DIGITS IN BCD
                    4186            ; BYTE X+4    = NEXT MOST SIGNIFICANT DIGITS IN BCD
                    4187            ; BYTE X+3    = NEXT LEAST SIGNIFICANT DIGITS IN BCD
                    4188            ; BYTE X+2    = LEAST SIGNIFICANT DIGITS IN BCD
                    4189            ; BYTE X+1    = SIGN OF THE ABOVE MANTISSA 0 = +, 1 = -
                    4190            ; BYTE X      = EXPONENT IN TWO'S COMPLEMENT BINARY
                    4191            ;               ZERO EXPONENT = THE NUMBER ZERO
                    4192            ;
                    4193            ;**************************************************************
                    4194            ;
112A 7E             4195    ATTAB:  DB      128-2           ; ARCTAN LOOKUP
112B 00             4196            DB      00H
112C 57             4197            DB      57H
112D 22             4198            DB      22H
112E 66             4199            DB      66H
112F 28             4200            DB      28H
