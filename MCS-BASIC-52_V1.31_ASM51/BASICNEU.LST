                    6394    ;
                    6395    ;*****************************************************************************
                    6396    ;****** Elektor 2 Patch ******************************************************
                    6397    ;****** Floting Point Error, found by D. Mudric and Z. Stojsavljevic *********
                    6398    ;
                    6399    ;       MOV     A,#9EH
                    6400    ;****** Error Number 1
                    6401    ;
                    6402    ;****** Value in R4 must be complemented with 100D (#9AH), it must be the
                    6403    ;****** first complement
                    6404    ;
                    6405    ;       CLR     C
                    6406    ;       SUBB    A,R4
                    6407    ;       DA      A
                    6408    ;       XCH     A,R4
                    6409    ;       JNZ     LOAD24
                    6410    ;       MOV     R4,A
                    6411    ;****** Error Number 2
                    6412    ;
                    6413    ;****** With substraction, after reducing both the minuend and the
                    6414    ;****** subtrahend to the same exponents, when R4 <> 0, it is obvious
                    6415    ;****** that one always has to make a borrowing from the first higher
                    6416    ;****** position of the minuend, not as it is stated by the original
                    6417    ;****** were it is made only when R4 = 50H
                    6418    ;
                    6419    ;LOAD24: CJNE    A,#50H,LOAD25   ;TEST FOR SUBTRACTION
                    6420    ;LOAD25: JNB     ADD_IN,SUBLP    ;DO SUBTRACTION IF NO ADD_IN
                    6421    ;
                    6422    ;*****************************************************************************
                    6423    ;****** Proper code starts here: *********************************************
                    6424    ;
19D7 749A           6425            mov     A,#9AH
19D9 C3             6426            clr     C
19DA 9C             6427            subb    A,R4
19DB D4             6428            da      A
19DC CC             6429            xch     A,R4
19DD 30231B         6430            jnb     ADD_IN,SUBLP
19E0 B45000         6431            cjne    A,#50H,LOAD25
                    6432    ;
                    6433    ;****** continue with original code: *****************************************
                    6434    ;
19E3 B3             6435    LOAD25: CPL     C               ;FLIP CARRY FOR ADDITION
19E4 31F2           6436            ACALL   ADDLP           ;DO ADDITION
                    6437            ;
19E6 5008           6438            JNC     ADD_R
19E8 052A           6439            INC     FP_CARRY
19EA 7F01           6440            MOV     R7,#1
19EC 71BB           6441            ACALL   RIGHT
