                     341            ; This is the equate table for 8052 basic.
                     342            ;
                     343            ;**************************************************************
                     344            ;
                     345            ; The register to direct equates for CJNE instructions.
                     346            ;
  0000               347    R0B0    EQU     0
  0001               348    R1B0    EQU     1
BASICNEU                                                                                                      PAGE 7

  0002               349    R2B0    EQU     2
  0003               350    R3B0    EQU     3
  0004               351    R4B0    EQU     4
  0005               352    R5B0    EQU     5
  0006               353    R6B0    EQU     6
  0007               354    R7B0    EQU     7
                     355            ;
                     356            ; Register bank 1 contains the text pointer
                     357            ; and the arg stack pointer.
                     358            ;
  0008               359    TXAL    EQU     8               ;R0 BANK 1 = TEXT POINTER LOW
  0009               360    ASTKA   EQU     9               ;R1 BANK 1 = ARG STACK
  000A               361    TXAH    EQU     10              ;R2 BANK 1 = TEXT POINTER HIGH
                     362            ;
                     363            ; Now five temporary locations that are used by basic.
                     364            ;
  000B               365    TEMP1   EQU     11
  000C               366    TEMP2   EQU     12
  000D               367    TEMP3   EQU     13
  000E               368    TEMP4   EQU     14
  000F               369    TEMP5   EQU     15
                     370            ;
                     371            ; Register bank 2 contains the read text pointer
                     372            ; and the control stack pointer.
                     373            ;
  0010               374    RTXAL   EQU     16              ;R0 BANK 2 = READ TEXT POINTER LOW
  0011               375    CSTKA   EQU     17              ;R1 BANK 2 = CONTROL STACK POINTER
  0012               376    RTXAH   EQU     18              ;R2 BANK 2 = READ TEXT POINTER HIGH
                     377            ;
                     378            ; Now some internal system equates.
                     379            ;
  0013               380    BOFAH   EQU     19              ;START OF THE BASIC PROGRAM, HIGH BYTE
  0014               381    BOFAL   EQU     20              ;START OF THE BASIC PROGRAM, LOW BYTE
  0015               382    NULLCT  EQU     21              ;NULL COUNT
  0016               383    PHEAD   EQU     22              ;PRINT HEAD POSITION
  0017               384    FORMAT  EQU     23
                     385            ;
                     386            ; Register bank 3 is for the user and can be loaded
                     387            ; by basic
                     388            ;
                     389            ;
                     390            ;
                     391            ; Now everything else is used by basic.
                     392            ; First the bit locations, these use bytes 34, 35, 36, 37 and 38
                     393            ;
  0010               394    OTS             BIT     16      ;34.0-ON TIME INSTRUCTION EXECUTED
  0011               395    INPROG          BIT     17      ;34.1-INTERRUPT IN PROCESS
  0012               396    INTBIT          BIT     18      ;34.2-INTERRUPT SET BIT
  0013               397    ON_ERR          BIT     19      ;34.3-ON ERROR EXECUTED
  0014               398    OTI             BIT     20      ;34.4-ON TIME INTERRUPT IN PROGRESS
  0015               399    LINEB           BIT     21      ;34.5-LINE CHANGE OCCURED
  0016               400    INTPEN          BIT     22      ;34.6-INTERRUPT PENDING BIT
  0017               401    CONB            BIT     23      ;34.7-CAN CONTINUE IF SET
  0018               402    GTRD            BIT     24      ;35.0-READ GET LOCATION
  0019               403    LPB             BIT     25      ;35.1-PRINT TO LINE PRINTER PORT
  001A               404    CKS_B           BIT     26      ;35.2-FOR PWM INTERRUPT
  001B               405    COB             BIT     27      ;35.3-CONSOLE OUT BIT
                     406                                    ;     0 = SERIAL PORT
