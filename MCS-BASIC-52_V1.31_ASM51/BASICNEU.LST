                    6135    ;       DB      '. 1','9'+80H,'85'
                    6136    ;
                    6137    ;*****************************************************************************
                    6138            ;
196B 22             6139    H_RET:  RET
                    6140            ;
                    6141    ;************************************************************
                    6142    ;
                    6143    ; This is a complete BCD floating point package for the 8051 micro-
                    6144    ; controller. It provides 8 digits of accuracy with exponents that
                    6145    ; range from +127 to -127. The mantissa is in packed BCD, while the
                    6146    ; exponent is expressed in pseudo-twos complement. A ZERO exponent
                    6147    ; is used to express the number ZERO. An exponent value of 80H or
                    6148    ; greater than means the exponent is positive, i.e. 80H = E 0,
                    6149    ; 81H = E+1, 82H = E+2 and so on. If the exponent is 7FH or less,
                    6150    ; the exponent is negative, 7FH = E-1, 7EH = E-2, and so on.
                    6151    ; ALL NUMBERS ARE ASSUMED TO BE NORMALIZED and all results are
                    6152    ; normalized after calculation. A normalized mantissa is >=.10 and
                    6153    ; <=.99999999.
BASICNEU                                                                                                      PAGE 108

                    6154    ;
                    6155    ; The numbers in memory assumed to be stored as follows:
                    6156    ;
                    6157    ; EXPONENT OF ARGUMENT 2   =   VALUE OF ARG_STACK+FP_NUMBER_SIZE
                    6158    ; SIGN OF ARGUMENT 2       =   VALUE OF ARG_STACK+FP_NUMBER_SIZE-1
                    6159    ; DIGIT 78 OF ARGUMENT 2   =   VALUE OF ARG_STACK+FP_NUMBER_SIZE-2
                    6160    ; DIGIT 56 OF ARGUMENT 2   =   VALUE OF ARG_STACK+FP_NUMBER_SIZE-3
                    6161    ; DIGIT 34 OF ARGUMENT 2   =   VALUE OF ARG_STACK+FP_NUMBER_SIZE-4
                    6162    ; DIGIT 12 OF ARGUMENT 2   =   VALUE OF ARG_STACK+FP_NUMBER_SIZE-5
                    6163    ;
                    6164    ; EXPONENT OF ARGUMENT 1   =   VALUE OF ARG_STACK
                    6165    ; SIGN OF ARGUMENT 1       =   VALUE OF ARG_STACK-1
                    6166    ; DIGIT 78 OF ARGUMENT 1   =   VALUE OF ARG_STACK-2
                    6167    ; DIGIT 56 OF ARGUMENT 1   =   VALUE OF ARG_STACK-3
                    6168    ; DIGIT 34 OF ARGUMENT 1   =   VALUE OF ARG_STACK-4
                    6169    ; DIGIT 12 OF ARGUMENT 1   =   VALUE OF ARG_STACK-5
                    6170    ;
                    6171    ; The operations are performed thusly:
                    6172    ;
                    6173    ; ARG_STACK+FP_NUMBER_SIZE = ARG_STACK+FP_NUMBER_SIZE # ARG_STACK
                    6174    ;
                    6175    ; Which is ARGUMENT 2 = ARGUMENT 2 # ARGUMENT 1
                    6176    ;
                    6177    ; Where # can be ADD, SUBTRACT, MULTIPLY OR DIVIDE.
                    6178    ;
                    6179    ; Note that the stack gets popped after an operation.
                    6180    ;
                    6181    ; The FP_COMP instruction POPS the ARG_STACK TWICE and returns status.
                    6182    ;
                    6183    ;**********************************************************************
                    6184    ;
                    6185    ;**********************************************************************
                    6186    ;
                    6187    ; STATUS ON RETURN - After performing an operation (+, -, *, /)
                    6188    ;                    the accumulator contains the following status
                    6189    ;
                    6190    ; ACCUMULATOR - BIT 0 - FLOATING POINT UNDERFLOW OCCURED
                    6191    ;
                    6192    ;             - BIT 1 - FLOATING POINT OVERFLOW OCCURED
                    6193    ;
                    6194    ;             - BIT 2 - RESULT WAS ZER0
                    6195    ;
                    6196    ;             - BIT 3 - DIVIDE BY ZERO ATTEMPTED
                    6197    ;
                    6198    ;             - BIT 4 - NOT USED, 0 RETURNED
                    6199    ;
                    6200    ;             - BIT 5 - NOT USED, 0 RETURNED
                    6201    ;
                    6202    ;             - BIT 6 - NOT USED, 0 RETURNED
                    6203    ;
                    6204    ;             - BIT 7 - NOT USED, 0 RETURNED
                    6205    ;
                    6206    ; NOTE: When underflow occures, a ZERO result is returned.
                    6207    ;       When overflow or divide by zero occures, a result of
                    6208    ;       .99999999 E+127 is returned and it is up to the user
                    6209    ;       to handle these conditions as needed in the program.
                    6210    ;
                    6211    ; NOTE: The Compare instruction returns F0 = 0 if ARG 1 = ARG 2
BASICNEU                                                                                                      PAGE 109

                    6212    ;       and returns a CARRY FLAG = 1 if ARG 1 is > ARG 2
                    6213    ;
                    6214    ;***********************************************************************
                    6215    ;
                    6216    ;***********************************************************************
                    6217    ;
                    6218    ; The following values MUST be provided by the user
                    6219    ;
                    6220    ;***********************************************************************
                    6221    ;
  0009              6222    ARG_STACK       EQU     9       ;ARGUMENT STACK POINTER
  0001              6223    ARG_STACK_PAGE  EQU     1
                    6224    ;OUTPUT          EQU     1990H   ;CALL LOCATION TO OUTPUT A CHARACTER
  0058              6225    CONVERT         EQU     58H     ;LOCATION TO CONVERT NUMBERS
  0019              6226    INTGRC          BIT     25      ;BIT SET IF INTGER ERROR
                    6227    ;
                    6228    ;***********************************************************************
                    6229    ;
                    6230    ; The following equates are used internally
                    6231    ;
                    6232    ;***********************************************************************
                    6233    ;
  0006              6234    FP_NUMBER_SIZE  EQU     6
  0000              6235    UNDERFLOW       EQU     0
  0001              6236    OVERFLOW        EQU     1
  0002              6237    ZERO            EQU     2
  0003              6238    ZERO_DIVIDE     EQU     3
                    6239    ;
                    6240    ;***********************************************************************
                    6241    ;
                    6242            ;**************************************************************
                    6243            ;
                    6244            ; The following internal locations are used by the math pack
                    6245            ; ordering is important and the FP_DIGITS must be bit
                    6246            ; addressable
                    6247            ;
                    6248            ;***************************************************************
                    6249            ;
  0028              6250    FP_STATUS       EQU     28H             ;NOT USED
  0029              6251    FP_TEMP         EQU     FP_STATUS+1     ;NOT USED
  002A              6252    FP_CARRY        EQU     FP_STATUS+2     ;USED FOR BITS
  0023              6253    ADD_IN          BIT     35              ;DCMPXZ IN BASIC BACKAGE
  0050              6254    XSIGN           BIT     FP_CARRY.0
  0051              6255    FOUND_RADIX     BIT     FP_CARRY.1
  0052              6256    FIRST_RADIX     BIT     FP_CARRY.2
  0053              6257    DONE_LOAD       BIT     FP_CARRY.3
  002B              6258    FP_DIG12        EQU     FP_CARRY+1
  002C              6259    FP_DIG34        EQU     FP_CARRY+2
  002D              6260    FP_DIG56        EQU     FP_CARRY+3
  002E              6261    FP_DIG78        EQU     FP_CARRY+4
  002F              6262    FP_SIGN         EQU     FP_CARRY+5
  0078              6263    MSIGN           BIT     FP_SIGN.0
  0030              6264    FP_EXP          EQU     FP_CARRY+6
  002B              6265    FP_NIB1         EQU     FP_DIG12
  002C              6266    FP_NIB2         EQU     FP_NIB1+1
  002D              6267    FP_NIB3         EQU     FP_NIB1+2
  002E              6268    FP_NIB4         EQU     FP_NIB1+3
  002F              6269    FP_NIB5         EQU     FP_NIB1+4
BASICNEU                                                                                                      PAGE 110

  0030              6270    FP_NIB6         EQU     FP_NIB1+5
  0031              6271    FP_NIB7         EQU     FP_NIB1+6
  0032              6272    FP_NIB8         EQU     FP_NIB1+7
  0033              6273    FP_ACCX         EQU     FP_NIB1+8
