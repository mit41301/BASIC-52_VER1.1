0010 02400B          264            LJMP    400BH           ;EXIT IF USER WANTS INTERRUPTS
                     265            ;
0013                 266            ORG     13H
                     267            ;
                     268            ;***************************************************************
                     269            ;
                     270            ;EXTERNAL INTERRUPT 1
