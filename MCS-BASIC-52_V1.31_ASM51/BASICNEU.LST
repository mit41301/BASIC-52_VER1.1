                     272            ;***************************************************************
                     273            ;
0013 20122B          274            JB      INTBIT,STK
0016 C0D0            275            PUSH    PSW
0018 024013          276            LJMP    4013H
                     277            ;
                     278            ;
001B                 279            ORG     1BH
                     280            ;
                     281            ;***************************************************************
                     282            ;
