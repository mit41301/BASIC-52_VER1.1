                     297            ;
0023                 298            ORG     23H
                     299            ;
0023 C0D0            300            PUSH    PSW
0025 201F1C          301            JB      SPINT,STU       ;SEE IF MONITOR EANTS INTERRUPT
0028 024023          302            LJMP    4023H
                     303            ;
002B                 304            ORG     2BH
