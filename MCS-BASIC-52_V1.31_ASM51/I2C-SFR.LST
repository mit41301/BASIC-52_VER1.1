I2C-SFR                                                                                                       PAGE 1

                       1    $MOD52
                       2    ;****************************************************************************
                       3    ;*                        BASIC-52 V1.31 enhancements                       *
                       4    ;*          The following code enhanced BASIC-52 with new commands          *
                       5    ;*               for I2C communicatin and read / write to SFR               *
                       6    ;*--------------------------------------------------------------------------*
                       7    ;* (C) H.-J. Boehling & D. Wulf 14.11.01                                    *
                       8    ;*     http://home.arcor.de/h.boehling                                      *
                       9    ;*     H-Boehling@gmx.de                                                    *
                      10    ;****************************************************************************
                      11    ;*
                      12    ;* Four new I2C communication commands as I2C-bus master.
                      13    ;*
                      14    ;* The syntax to use is:
                      15    ;*
                      16    ;*     I2CSTART           Sends a start condition to I2C bus.
                      17    ;*                        - Returns with busy, time out or status clear.  
                      18    ;*     I2CSTOP            Sends a stop condition to I2C bus.
                      19    ;*                        - Returns with time out or status clear.
                      20    ;*     I2CPUT [byte]      Sends a byte to the I2C bus.
                      21    ;*                        - Returns with time out, no acknowledge or clear.
                      22    ;*     I2CGET [variable]  Reads a byte from I2C to a BASIC variable.
                      23    ;*                        - Set 18H (status) to 1 to send no acknowledge:
                      24    ;*                           DBY(18H) = 1 : I2CGET B : I2CSTOP : PRINT B
                      25    ;*                        - Returns with time out or status clear. 
                      26    ;*   
                      27    ;* Register 18H is the I2C communication status register; useage is:
                      28    ;*
                      29    ;*     STATUS=DBY(18H)
                      30    ;*      IF STATUS.AND.2=2 PRINT "Time out error!"
                      31    ;*      IF STATUS.AND.4=4 PRINT "Busy error!"
                      32    ;*      IF STATUS.AND.8=8 PRINT "No acknowlege error!"
                      33    ;*
                      34    ;*---------------------------------------------------------------------------
                      35    ;*
                      36    ;* Two new commands to read from or write to a special funkton register:
                      37    ;*
                      38    ;*     WRSFR ([address]) [byte]      Writes to a special funkton register.
                      39    ;*
                      40    ;*     RDSFR ([address]) [variable]  Reads from a special funkton register.
                      41    ;*
                      42    ;* [address] is the address of the SFR and had to be a value between 
                      43    ;* 128 (080H) and 255 (0FFH).
                      44    ;*
                      45    ;****************************************************************************
                      46    
                      47    ;----- Definitions ----------------------------------------------------------
                      48    
  0096                49    SDA             bit     P1.6                    ;I2C serial data line.
  0095                50    SCL             bit     P1.5                    ;I2C serial clock line.
                      51    
  0018                52    status          equ     018H                    ;Communication status.
                      53    
  000B                54    temp1           equ     11                      ;Temp. storage.
                      55    
  002D                56    xbit            bit     45                      ;Command extension present.
                      57     
                      58    ; the following bits will be set in the status byte:
I2C-SFR                                                                                                       PAGE 2

                      59    
  0002                60    tout            equ     00000010B               ;I2C time out status.
  0004                61    busy            equ     00000100B               ;I2C bus busy status.
  0008                62    nack            equ     00001000B               ;Slave sends no acknowledge.
                      63                                                    
                      64    ;----------------------------------------------------------------------------
                      65    ; The following code is necessary to notify the new statements to BASIC.
                      66    
2002                  67                    org     2002H                   ;5Ah at 2002h tells BASIC-52
2002 5A               68                    db      5AH                     ;to call 2048h (see below).
2048                  69                    org     2048H                   ;Set bit 45 to tell BASIC-52
                      70                                                    ;that custom commands or
2048 D22D             71                    setb    xbit                    ;instructions have been
204A 22               72                    ret                             ;added.
2070                  73                    org     2070H                   ;Store starting address of
2070 902400           74                    mov     dptr,#vectortable       ;vector table.
2073 22               75                    ret
2078                  76                    org     2078H                   ;Store starting address of
2078 90240C           77                    mov     dptr,#tokentable        ;token table.
207B 22               78                    ret
                      79    
                      80    ; The old code for BASIC-52 V1.3 overwrite 2090H, but this address had to be
                      81    ; used for a user reset routine! So the code now starts at here:
                      82    
                      83    ;===== Here starts the code for the new BASIC statements ====================
                      84    
2400                  85                    org     2400h                   ;use any available address
                      86    
2400                  87    vectortable:                                    ;Vector table starts here.
                      88                                                    ;Label to branch on:
2400 2440             89                    dw      i2cstart                ;I2CSTART command
2402 2456             90                    dw      i2cstop                 ;I2CSTOP command
2404 2462             91                    dw      i2cput                  ;I2CPUT command
2406 2492             92                    dw      i2cget                  ;I2CGET command
2408 2541             93                    dw      wrsfr                   ;WRSFR command
240A 2519             94                    dw      rdsfr                   ;RDSFR command
                      95    
240C                  96    tokentable:                                     ;Token table starts here.
240C 10               97                    db      10H                     ;1. user defined token for
240D 49324353         98                    db      'I2CSTART'              ;command name.
2411 54415254   
2415 00               99                    db      0                       ;End of token indicator
2416 11              100                    db      11H                     ;2.
2417 49324353        101                    db      'I2CSTOP'
241B 544F50     
241E 00              102                    db      0
241F 12              103                    db      12H                     ;3.
2420 49324350        104                    db      'I2CPUT'
2424 5554       
2426 00              105                    db      0
2427 13              106                    db      13H                     ;4.
2428 49324347        107                    db      'I2CGET'
242C 4554       
242E 00              108                    db      0
242F 14              109                    db      14H                     ;5.
2430 57525346        110                    db      'WRSFR'
2434 52         
2435 00              111                    db      0
I2C-SFR                                                                                                       PAGE 3

2436 15              112                    db      15H                     ;6.
2437 52445346        113                    db      'RDSFR'
243B 52         
243C 00              114                    db      0
                     115    
                     116    ;----- The following is necessary to get no problem with variable names -----
                     117    
243D DF              118                    db      0DFH                    ;Dummy token.
243E 7F              119                    db      07FH                    ;Unused dummy char.
                     120    
                     121    ;----------------------------------------------------------------------------
                     122    
243F FF              123                    db      0FFH                    ;End of tokenlist indicator.
                     124    
                     125    ;----------------------------------------------------------------------------
                     126    
                     127    ;===== i2cstart - sends an I2C start condition to beginn communication ======
                     128    
2440 1224BA          129    i2cstart:       call    SCLhigh                 ;Set SCL to high.
2443 7F04            130                    mov     R7,#4                   ;Load time out counter.
2445 D296            131    setSDA:         setb    SDA                     ;Set SDA to high.
2447 209606          132                    jb      SDA,ishigh              ;If not high bus is busy.
244A DFF9            133                    djnz    R7,setSDA               ;If not try until R7 is zero.
244C 431804          134                    orl     status,#busy            ;Set busy status.
244F 22              135                    ret                             ;return to BASIC.
                     136    
2450 C296            137    ishigh:         clr     SDA                     ;Set start condition.
2452 531800          138                    anl     status,#0               ;Clear I2C status.
2455 22              139                    ret                             ;return to BASIC.
                     140    
                     141    ;===== i2cstop - sends an I2C stop condition to end communication ===========
                     142    
2456 531800          143    i2cstop:        anl     status,#0               ;Clear I2C status.
2459 C296            144                    clr     SDA                     ;Get SDA ready for stop.
245B 91BA            145                    acall   SCLhigh                 ;Set clock for stop.
245D 91B9            146                    acall   delay                   ;Delay 4 machine cycles.
245F D296            147                    setb    SDA                     ;Set stop condition.
2461 22              148                    ret                             ;Return to BASIC.
                     149    
                     150    ;===== i2cput - sends a byte from a BASIC value out to the I2C bus ==========
                     151    
                     152    ;----- Get value and test for 8 bit only ------------------------------------
                     153    
2462 7439            154    i2cput:         mov     A,#39H                  ;Put value to send on
2464 120030          155                    lcall   30H                     ;argument stack.
2467 7401            156                    mov     A,#1                    ;change value to 16 bit
2469 120030          157                    lcall   30H                     ;integer and write to R3:R1
246C BB0058          158                    cjne    R3,#0,i2cerror          ;If R3 not zero then 
                     159                                                    ;value bigger than 0FFH.
                     160                                                    ;8 bit integer only error.
                     161    
                     162    ;----- Send byte to I2C bus -------------------------------------------------
                     163    
246F E9              164                    mov     A,R1                    ;Load byte to send.
2470 7E08            165                    mov     R6,#8                   ;Load bit counter
2472 C295            166    send:           clr     SCL                     ;Make clock low
2474 91B9            167                    acall   delay                   ;Delay 4 machine cycles.
2476 33              168                    rlc     A                       ;Rotate data bit to C.
I2C-SFR                                                                                                       PAGE 4

2477 9296            169                    mov     SDA,C                   ;Put data bit on pin.
2479 91BA            170                    acall   SCLhigh                 ;Send clock.
247B 91B9            171                    acall   delay                   ;Delay 4 machine cycles.
247D DEF3            172                    djnz    R6,send                 ;Repeat until all bits sent.
                     173    
                     174    ;----- Read acknowledge from slave ------------------------------------------
                     175            
247F C295            176                    clr     SCL                     ;Make clock low.
2481 91B9            177                    acall   delay                   ;Delay 4 machine cycles.
2483 D296            178                    setb    SDA                     ;Release line for acknowledge.
2485 91BA            179                    acall   SCLhigh                 ;Send clock for acknowlege.
2487 91B9            180                    acall   delay                   ;Delay 4 machine cycles.
2489 309603          181                    jnb     SDA,ackok               ;Check for valid acknowledge.
248C 431808          182                    orl     status,#nack            ;Set no acknowledge status.
248F C295            183    ackok:          clr     SCL                     ;Finish acknowledge bit.
2491 22              184                    ret                             ;Return to BASIC.
                     185    
                     186    ;===== i2cget - Reads one byte from I2C bus to the argument stack ===========
                     187    
2492 7E08            188    i2cget:         mov     R6,#8                   ;Load bit counter
2494 C295            189    read:           clr     SCL                     ;Make clock low.
2496 91B9            190                    acall   delay                   ;Delay 4 machine cycles.
2498 91BA            191                    acall   SCLhigh                 ;Send clock.
249A 91B9            192                    acall   delay                   ;Delay 4 machine cycles.
249C A296            193                    mov     C,SDA                   ;Get data bit from pin.
249E 33              194                    rlc     A                       ;Rotate bit into result byte.
249F DEF3            195                    djnz    R6,read                 ;Repeat until all received.
                     196    
                     197    ;----- Put received byte on argument stack ----------------------------------
                     198    
24A1 F8              199                    mov     R0,A                    ;Load R0 with reseived byte.
24A2 7A00            200                    mov     R2,#0                   ;Set high byte to zero.
24A4 749A            201                    mov     A,#9AH                  ;Put byte on argument stack
24A6 120030          202                    lcall   30H                     ;with BASIC funktion.
                     203    
                     204    ;----- Send acknowledge to slave --------------------------------------------
                     205    
24A9 C295            206                    clr     SCL                     ;Set clock low.
24AB 91B9            207                    acall   delay                   ;Delay 4 machine cycles.
24AD E518            208                    mov     A,status                ;Load acknowledge bit
24AF 13              209                    rrc     A                       ;into C and
24B0 9296            210                    mov     SDA,C                   ;send acknowledge bit.
24B2 91BA            211                    acall   SCLhigh                 ;Send acknowledge clock.
                     212    
                     213    ;----- Set variable to received byte ----------------------------------------
                     214    
24B4 7443            215                    mov     A,#43H                  ;Set next variable to value
24B6 020030          216                    ljmp    30H                     ;on argument stack and
                     217                                                    ;return to BASIC.
                     218    
                     219    ;----- delay - generates a delay of 4 machine cycles ------------------------
                     220    
24B9 22              221    delay:          ret                             ;4 cycles for CALL and RET.
                     222    
                     223    ;----- SCLhigh - sends SCL pin high and waits for any clock stretching ------
                     224    
24BA 7F04            225    SCLhigh:        mov     R7,#4                   ;Load time out counter.
24BC D295            226    setSCL:         setb    SCL                     ;Set SCL to high.
I2C-SFR                                                                                                       PAGE 5

24BE 209505          227                    jb      SCL,quit                ;If SCL actually high return.
24C1 DFF9            228                    djnz    R7,setSCL               ;If not try until R7 is zero.
24C3 431802          229                    orl     status,#tout            ;Set status time out.
24C6 22              230    quit:           ret
                     231    
                     232    ;----- error - sends an error message to the terminal -----------------------
                     233    
24C7 7407            234    i2cerror:       mov     A,#7                    ;Send CR/LF
24C9 120030          235                    lcall   30H
24CC 7B24            236                    mov     R3,#high i2cerrmsg      ;Set string address.
24CE 79DB            237                    mov     R1,#low i2cerrmsg
24D0 D234            238    error:          setb    34H                     ;Read string from code memory.
24D2 7406            239                    mov     A,#6                    ;Send String to
24D4 120030          240                    lcall   30H                     ;terminal.
24D7 E4              241                    clr     A
24D8 020030          242                    ljmp    30H                     ;Back to command mode.
                     243    
24DB 4552524F        244    i2cerrmsg:      db 'ERROR: BAD I2CPUT ARGUMENT'
24DF 523A2042   
24E3 41442049   
24E7 32435055   
24EB 54204152   
24EF 47554D45   
24F3 4E54       
24F5 22              245                    db      22H                     ;End of text.   
                     246    
24F6 4552524F        247    sfrerrmsg:      db 'ERROR: BAD SFR ARGUMENT'
24FA 523A2042   
24FE 41442053   
2502 46522041   
2506 5247554D   
250A 454E54     
250D 22              248                    db      22H                     ;End of text.
                     249    
250E 7407            250    sfrerror:       mov     A,#7                    ;Send CR/LF
2510 120030          251                    lcall   30H
2513 7B24            252                    mov     R3,#high sfrerrmsg      ;Set string address.
2515 79F6            253                    mov     R1,#low sfrerrmsg
2517 80B7            254                    sjmp    error
                     255    
                     256    ;===== rdsfr - read from special funtion register ==========================
                     257    
2519 7439            258    rdsfr:          mov     A,#39H                  ;Put address from text to
251B 120030          259                    lcall   30H                     ;argument stack.
                     260    
251E 7401            261                    mov     A,#1                    ;change value to 16 bit
2520 120030          262                    lcall   30H                     ;integer and write to R3:R1
                     263    
2523 BB00E8          264                    cjne    R3,#0,sfrerror          ;If R3 not zero then error.
2526 E9              265                    mov     A,R1                    ;Address to Acc.
2527 30E7E4          266                    jnb     Acc.7,sfrerror          ;If address less then 80H! 
252A FC              267                    mov     R4,A                    ;Address to R4.
                     268    
252B 758288          269                    mov     DPL,#low sfrgettab      ;Set DPTR to jump
252E 758325          270                    mov     DPH,#high sfrgettab     ;table.
2531 122569          271                    call    do_sfr                  ;Read SFR.
                     272    
2534 F8              273                    mov     R0,A                    ;Load R0 with SFR byte.
I2C-SFR                                                                                                       PAGE 6

2535 7A00            274                    mov     R2,#0                   ;Set high byte to zero.
2537 749A            275                    mov     A,#9AH                  ;Put byte on argument stack
2539 120030          276                    lcall   30H
                     277    
                     278    ;----- Set variable to SFR byte ---------------------------------------------
                     279    
253C 7443            280                    mov     A,#43H                  ;Set next variable to value
253E 020030          281                    ljmp    30H                     ;on argument stack and
                     282                                                    ;return to BASIC.
                     283    
                     284    ;===== wrsfr - write to special funtion register ============================
                     285    
2541 7439            286    wrsfr:          mov     A,#39H                  ;Put address from text to
2543 120030          287                    lcall   30H                     ;argument stack.
                     288    
2546 7401            289                    mov     A,#1                    ;change value to 16 bit
2548 120030          290                    lcall   30H                     ;integer and write to R3:R1
254B BB00C0          291                    cjne    R3,#0,sfrerror          ;If R3 not zero then error
254E E9              292                    mov     A,R1                    ;or
254F 30E7BC          293                    jnb     Acc.7,sfrerror          ;if address less then 80H! 
2552 890B            294                    mov     temp1,R1                ;Save address.
                     295    
2554 7439            296                    mov     A,#39H                  ;Put value to write on
2556 120030          297                    lcall   30H                     ;argument stack.
                     298    
2559 7401            299                    mov     A,#1                    ;change value to 16 bit
255B 120030          300                    lcall   30H                     ;integer and write to R3:R1
255E BB00AD          301                    cjne    R3,#0,sfrerror          ;If R3 not zero then 
                     302                                                    ;8 bit integer only error.
2561 758286          303                    mov     DPL,#low sfrputtab      ;Set DPTR to jump
2564 758325          304                    mov     DPH,#high sfrputtab     ;table.
2567 AC0B            305                    mov     R4,temp1                ;Address to write to R4.
                     306    
                     307    ;----- do_sfr - read from or wright to SFR ----------------------------------
                     308    
                     309    ;----- Calculate the jump ---------------------------------------------------
                     310    
2569 EC              311    do_sfr:         mov     A,R4                    ;Address to Acc
256A 2480            312                    add     A,#80H
256C FC              313                    mov     R4,A
256D 7800            314                    mov     R0,#0
256F 25E0            315                    add     A,ACC                   ;*2
2571 C8              316                    xch     A,R0
2572 35E0            317                    addc    A,ACC                   ;carry
2574 C8              318                    xch     A,R0
2575 25E0            319                    add     A,ACC                   ;*4
2577 C8              320                    xch     A,R0
2578 35E0            321                    addc    A,ACC                   ;carry
257A C8              322                    xch     A,R0
                     323    
                     324    ;----- Load DPTR with offset and jump ---------------------------------------
                     325    
257B 2582            326                    add     A,DPL
257D F582            327                    mov     DPL,A
257F E8              328                    mov     A,R0
2580 3583            329                    addc    A,DPH
2582 F583            330                    mov     DPH,A
2584 EC              331                    mov     A,R4
I2C-SFR                                                                                                       PAGE 7

2585 73              332                    jmp     @A+DPTR                 ;Jump into table.
                     333    
