   71:					;
   72:	  0000	61 87			AJMP	CRST		;START THE PROGRAM
   73:					;
   74:		N      0003		ORG	3H
   75:					;
   76:					;***************************************************************
   77:					;
   78:					;EXTERNAL INTERRUPT 0
   79:					;
   80:					;***************************************************************
