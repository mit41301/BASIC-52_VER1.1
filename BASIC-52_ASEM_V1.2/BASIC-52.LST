 3930:	  118B	31 96			ACALL	AMUL		;MULTIPLY CONSTANT AND COMPUTED VALUE
 3931:	  118D	91 19			ACALL	PUSHC		;PUT NEXT CONSTANT ON STACK
 3932:	  118F	F1 33			ACALL	AADD		;ADD IT TO THE OLD VALUE
 3933:	  1191	E4			CLR	A		;CHECK TO SEE IF DONE
