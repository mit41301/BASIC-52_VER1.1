 4937:					;***************************************************************
 4938:					;
 4939:					; PP - Preprocesses the line in IBUF back into IBUF
 4940:					;      sets F0 if no line number
 4941:					;      leaves the correct length of processed line in IBCNT
 4942:					;      puts the line number in IBLN
 4943:					;      wastes the text address TXAL and TXAH
 4944:					;
 4945:					;***************************************************************
 4946:					;
 4947:	  15A0	F1 5E		PP:	ACALL	T_BUF		;TXA GETS IBUF
 4948:	  15A2	12 0F 33		CALL	INTGER		;SEE IF A NUMBER PRESENT
 4949:	  15A5	12 18 49		CALL	TEMPD		;SAVE THE INTEGER IN TEMP5:TEMP4
 4950:	  15A8	92 D5			MOV	F0,C		;SAVE INTEGER IF PRESENT
 4951:	  15AA	90 00 05		MOV	DPTR,#IBLN	;SAVE THE LINE NUMBER, EVEN IF NONE
 4952:	  15AD	91 0A			ACALL	S20DP
 4953:	  15AF	A8 08			MOV	R0,TXAL		;TEXT POINTER
 4954:	  15B1	79 07			MOV	R1,#LOW IBUF	;STORE POINTER
 4955:					;
 4956:					; Now process the line back into IBUF
 4957:					;
 4958:	  15B3	C2 24		PPL:	CLR	ARGF		;FIRST PASS DESIGNATOR
 4959:	  15B5	90 01 73		MOV	DPTR,#TOKTAB	;POINT DPTR AT LOOK UP TABLE
 4960:					;
 4961:	  15B8	88 05		PPL1:	MOV	R5B0,R0		;SAVE THE READ POINTER
 4962:	  15BA	E4			CLR	A		;ZERO A FOR LOOKUP
 4963:	  15BB	93			MOVC	A,@A+DPTR	;GET THE TOKEN
 4964:	  15BC	FF			MOV	R7,A		;SAVE TOKEN IN CASE OF MATCH
 4965:					;
 4966:	  15BD	E2		PPL2:	MOVX	A,@R0		;GET THE USER CHARACTER
 4967:	  15BE	FB			MOV	R3,A		;SAVE FOR REM
 4968:	  15BF	B4 61 00		CJNE	A,#'a',$+3
 4969:	  15C2	40 07			JC	PPX		;CONVERT LOWER TO UPPER CASE
 4970:	  15C4	B4 7B 00		CJNE	A,#('z'+1),$+3
 4971:	  15C7	50 02			JNC	PPX
 4972:	  15C9	C2 E5			CLR	ACC.5
 4973:					;
 4974:	  15CB	FA		PPX:	MOV	R2,A
 4975:	  15CC	F2			MOVX	@R0,A		;SAVE UPPER CASE
 4976:	  15CD	A3			INC	DPTR		;BUMP THE LOOKUP POINTER
 4977:	  15CE	E4			CLR	A
 4978:	  15CF	93			MOVC	A,@A+DPTR
 4979:	  15D0	B5 02 03		CJNE	A,R2B0,PPL3	;LEAVE IF NOT THE SAME
 4980:	  15D3	08			INC	R0		;BUMP THE USER POINTER
 4981:	  15D4	80 E7			SJMP	PPL2		;CONTINUE TO LOOP
 4982:					;
 4983:	  15D6	20 E7 2F	PPL3:	JB	ACC.7,PPL6	;JUMP IF FOUND MATCH
 4984:	  15D9	60 2D			JZ	PPL6		;USER MATCH
 4985:					;
 4986:					;
 4987:					; Scan to the next TOKTAB entry
 4988:					;
 4989:	  15DB	A3		PPL4:	INC	DPTR		;ADVANCE THE POINTER
 4990:	  15DC	E4			CLR	A		;ZERO A FOR LOOKUP
 4991:	  15DD	93			MOVC	A,@A+DPTR	;LOAD A WITH TABLE
 4992:	  15DE	20 E7 03		JB	ACC.7,$+6	;KEEP SCANNING IF NOT A RESERVED WORD

ASEM-51 V1.2                                        Copyright (c) 1996 by W.W. Heinz                                        PAGE 122



 Line  I  Addr  Code            Source

 4993:	  15E1	70 F8			JNZ	PPL4
 4994:	  15E3	A3			INC	DPTR
 4995:					;
 4996:					; See if at the end of TOKTAB
 4997:					;
 4998:	  15E4	A8 05			MOV	R0,R5B0		;RESTORE THE POINTER
 4999:	  15E6	B4 FF CF		CJNE	A,#0FFH,PPL1	;SEE IF END OF TABLE
 5000:					;
 5001:					; Character not in TOKTAB, so see what it is
 5002:					;
 5003:	  15E9	BA 20 03		CJNE	R2,#' ',PPLX	;SEE IF A SPACE
 5004:	  15EC	08			INC	R0		;BUMP USER POINTER
 5005:	  15ED	80 C4			SJMP	PPL		;TRY AGAIN
 5006:					;
 5007:	  15EF	30 2D 0A	PPLX:	JNB	XBIT,PPLY	;EXTERNAL TRAP
 5008:	  15F2	20 24 07		JB	ARGF,PPLY
 5009:	  15F5	D2 24			SETB	ARGF		;SAYS THAT THE USER HAS TABLE
 5010:	  15F7	12 20 78		LCALL	2078H		;SET UP POINTER
 5011:	  15FA	A1 B8			AJMP	PPL1
 5012:					;
 5013:	  15FC	D1 15		PPLY:	ACALL	PPL7		;SAVE CHARACTER, EXIT IF A CR
 5014:	  15FE	B4 22 B2		CJNE	A,#'"',PPL	;SEE IF QUOTED STRING, START AGAIN IF NOT
 5015:					;
 5016:					; Just copy a quoted string
 5017:					;
 5018:	  1601	D1 15			ACALL	PPL7		;SAVE THE CHARACTER, TEST FOR CR
 5019:	  1603	B4 22 FB		CJNE	A,#'"',$-2	;IS THERE AN ENDQUOTE, IF NOT LOOP
 5020:	  1606	80 AB			SJMP	PPL		;DO IT AGAIN IF ENDQUOTE
 5021:					;
 5022:	  1608	EF		PPL6:	MOV	A,R7		;GET THE TOKEN
 5023:	  1609	D1 2A			ACALL	PPL9+1		;SAVE THE TOKEN
 5024:	  160B	B4 96 A5		CJNE	A,#T_REM,PPL	;SEE IF A REM TOKEN
 5025:	  160E	EB			MOV	A,R3
 5026:	  160F	D1 16			ACALL	PPL7+1		;WASTE THE REM STATEMENT
 5027:	  1611	D1 15			ACALL	PPL7		;LOOP UNTIL A CR
 5028:	  1613	80 FC			SJMP	$-2
 5029:					;
 5030:	  1615	E2		PPL7:	MOVX	A,@R0		;GET THE CHARACTER
 5031:	  1616	B4 0D 10		CJNE	A,#CR,PPL9	;FINISH IF A CR
 5032:	  1619	D0 00			POP	R0B0		;WASTE THE CALLING STACK
 5033:	  161B	D0 00			POP	R0B0
 5034:	  161D	F3			MOVX	@R1,A		;SAVE CR IN MEMORY
 5035:	  161E	09			INC	R1		;SAVE A TERMINATOR
 5036:	  161F	74 01			MOV	A,#EOF
 5037:	  1621	F3			MOVX	@R1,A
 5038:	  1622	E9			MOV	A,R1		;SUBTRACT FOR LENGTH
 5039:	  1623	94 04			SUBB	A,#4
 5040:	  1625	F5 0D			MOV	TEMP3,A		;SAVE LENGTH
 5041:	  1627	79 04			MOV	R1,#LOW IBCNT	;POINT AT BUFFER COUNT
 5042:					;
 5043:	  1629	08		PPL9:	INC	R0
 5044:	  162A	F3			MOVX	@R1,A		;SAVE THE CHARACTER
 5045:	  162B	09			INC	R1		;BUMP THE POINTERS
 5046:	  162C	22			RET			;EXIT TO CALLING ROUTINE
 5047:					;
 5048:					;

