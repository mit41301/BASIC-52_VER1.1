 4778:					;
 4779:					;EXPAND FOR A NEW LINE OR A LARGER LINE
 4780:					;
 4781:	  150E	FF		LTX:	MOV	R7,A		;SAVE A IN R7
 4782:	  150F	E5 0D			MOV	A,TEMP3		;GET THE COUNT IN THE ACC
 4783:	  1511	B4 04 01		CJNE	A,#04H,$+4	;DO NO INSERTATION IF NULL LINE
 4784:	  1514	22			RET			;EXIT IF IT IS
 4785:					;
 4786:	  1515	EF			MOV	A,R7		;GET THE COUNT BACK - DELTA IN A
