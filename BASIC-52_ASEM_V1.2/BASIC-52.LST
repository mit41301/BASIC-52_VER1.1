 4792:	  1522	AB 05			MOV	R3,R5B0		;EOFA HIGH
 4793:	  1524	0E			INC	R6		;INCREMENT BYTE COUNT
 4794:	  1525	BE 00 01		CJNE	R6,#00,$+4	;NEED TO BUMP HIGH BYTE?
