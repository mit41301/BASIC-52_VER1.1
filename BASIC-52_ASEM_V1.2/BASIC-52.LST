 1120:	  046A	12 0E DF		CALL	DELTST		;SEE IF A CR
 1121:	  046D	70 D0			JNZ	PG8		;SAVE TIMER IF SO
 1122:	  046F	7C FE			MOV	R4,#0FEH
 1123:	  0471	D2 1D			SETB	INBIT
