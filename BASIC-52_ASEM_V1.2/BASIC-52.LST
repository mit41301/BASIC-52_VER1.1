 4902:					;
 4903:					;***************************************************************
 4904:					;
 4905:	  1583	EC		NMOV:	MOV	A,R4		;THE LOW BYTE OF EOFA
 4906:	  1584	C3			CLR	C		;CLEAR THE CARRY FOR SUBB
 4907:	  1585	95 82			SUBB	A,DPL		;SUBTRACT DATA POINTER LOW
 4908:	  1587	FE			MOV	R6,A		;PUT RESULT IN R6
 4909:	  1588	ED			MOV	A,R5		;HIGH BYTE OF EOFA
 4910:	  1589	95 83			SUBB	A,DPH		;SUBTRACT DATA POINTER HIGH
 4911:	  158B	FF			MOV	R7,A		;PUT RESULT IN R7
 4912:	  158C	4E			ORL	A,R6		;SEE IF ZERO
 4913:	  158D	22			RET			;EXIT
 4914:					;
 4915:					;***************************************************************
 4916:					;
 4917:					;CHECK FOR A FILE OVERFLOW
