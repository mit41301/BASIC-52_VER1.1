 4922:					;
 4923:	  158E	2C		FULL:	ADD	A,R4		;ADD A TO END ADDRESS
 4924:	  158F	F9			MOV	R1,A		;SAVE IT
 4925:	  1590	E4			CLR	A
 4926:	  1591	3D			ADDC	A,R5		;ADD THE CARRY
 4927:	  1592	FB			MOV	R3,A
 4928:	  1593	90 01 04		MOV	DPTR,#VARTOP	;POINT AT VARTOP
 4929:					;
 4930:	  1596	12 05 C4	FUL1:	CALL	DCMPX		;COMPARE THE TWO
 4931:	  1599	40 F2			JC	FULL-1		;OUT OF ROOM
 4932:					;
 4933:	  159B	90 18 0B	TB:	MOV	DPTR,#E5X	;OUT OF MEMORY
