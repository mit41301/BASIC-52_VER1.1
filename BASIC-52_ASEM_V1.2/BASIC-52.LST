 5669:	  192A	12 0E D3		LCALL	GCI		;GET THE CHARACTER, CLEARS CARRY
 5670:	  192D	94 31			SUBB	A,#'1'		;SEE IF A ONE
 5671:	  192F	B3			CPL	C		;SETS CARRY IF ONE, CLEARS IT IF ZERO
