 3771:					;**************************************************************
 3772:					;
 3773:					; This table contains all of the floating point constants
 3774:					;
 3775:					; The constants in ROM are stored "backwards" from the way
 3776:					; basic normally treats floating point numbers. Instead of
 3777:					; loading from the exponent and decrementing the pointer,
 3778:					; ROM constants pointers load from the most significant
 3779:					; digits and increment the pointers. This is done to 1) make
 3780:					; arg stack loading faster and 2) compensate for the fact that
 3781:					; no decrement data pointer instruction exsist.
 3782:					;
 3783:					; The numbers are stored as follows:
 3784:					;
 3785:					; BYTE X+5    = MOST SIGNIFICANT DIGITS IN BCD
 3786:					; BYTE X+4    = NEXT MOST SIGNIFICANT DIGITS IN BCD
 3787:					; BYTE X+3    = NEXT LEAST SIGNIFICANT DIGITS IN BCD
 3788:					; BYTE X+2    = LEAST SIGNIFICANT DIGITS IN BCD
 3789:					; BYTE X+1    = SIGN OF THE ABOVE MANTISSA 0 = +, 1 = -
 3790:					; BYTE X      = EXPONENT IN TWO'S COMPLEMENT BINARY
 3791:					;               ZERO EXPONENT = THE NUMBER ZERO
 3792:					;
 3793:					;**************************************************************
 3794:					;
 3795:	  1110	7E		ATTAB:	DB	128-2		; ARCTAN LOOKUP
 3796:	  1111	00			DB	00H
 3797:	  1112	57			DB	57H
 3798:	  1113	22			DB	22H
 3799:	  1114	66			DB	66H
 3800:	  1115	28			DB	28H
 3801:					;
 3802:	  1116	7F			DB	128-1
 3803:	  1117	01			DB	01H
 3804:	  1118	37			DB	37H
