 4728:					;***************************************************************
 4729:					;
 4730:					;THIS IS THE LINE EDITOR
 4731:					;
 4732:					;TAKE THE PROCESSED LINE IN IBUF AND INSERT IT INTO THE
 4733:					;BASIC TEXT FILE.
 4734:					;
 4735:					;***************************************************************
 4736:					;
 4737:	  14D3	02 05 66		LJMP	NOGO		;CAN'T EDIT A ROM
 4738:					;
 4739:	  14D6	E5 13		LINE:	MOV	A,BOFAH
 4740:	  14D8	B4 02 F8		CJNE	A,#HIGH PSTART,LINE-3
 4741:	  14DB	12 05 A1		CALL	G4		;GET END ADDRESS FOR EDITING
 4742:	  14DE	AC 82			MOV	R4,DPL
 4743:	  14E0	AD 83			MOV	R5,DPH
 4744:	  14E2	AB 0F			MOV	R3,TEMP5	;GET HIGH ORDER IBLN
 4745:	  14E4	A9 0E			MOV	R1,TEMP4	;LOW ORDER IBLN
 4746:					;
 4747:	  14E6	12 05 84		CALL	GETLIN		;FIND THE LINE
 4748:	  14E9	70 12			JNZ	INSR		;INSERT IF NOT ZERO, ELSE APPEND
 4749:					;
 4750:					;APPEND THE LINE AT THE END
 4751:					;
 4752:	  14EB	E5 0D			MOV	A,TEMP3		;PUT IBCNT IN THE ACC
 4753:	  14ED	B4 04 01		CJNE	A,#4H,$+4	;SEE IF NO ENTRY
 4754:	  14F0	22			RET			;RET IF NO ENTRY
 4755:					;
 4756:	  14F1	B1 8E			ACALL	FULL		;SEE IF ENOUGH SPACE LEFT
 4757:	  14F3	AA 05			MOV	R2,R5B0		;PUT END ADDRESS A INTO TRANSFER
 4758:	  14F5	A8 04			MOV	R0,R4B0		;REGISTERS
 4759:	  14F7	B1 4C			ACALL	IMOV		;DO THE BLOCK MOVE
 4760:					;
 4761:	  14F9	74 01		UE:	MOV	A,#EOF		;SAVE EOF CHARACTER
 4762:	  14FB	A1 7F			AJMP	TBR
 4763:					;
 4764:					;INSERT A LINE INTO THE FILE
 4765:					;
 4766:	  14FD	FF		INSR:	MOV	R7,A		;SAVE IT IN R7
 4767:	  14FE	12 18 49		CALL	TEMPD		;SAVE INSERATION ADDRESS
 4768:	  1501	E5 0D			MOV	A,TEMP3		;PUT THE COUNT LENGTH IN THE ACC
 4769:	  1503	40 09			JC	LTX		;JUMP IF NEW LINE # NOT = OLD LINE #
 4770:	  1505	B4 04 01		CJNE	A,#04H,$+4	;SEE IF NULL
 4771:	  1508	E4			CLR	A
 4772:					;
 4773:	  1509	9F			SUBB	A,R7		;SUBTRACT LINE COUNT FROM ACC
 4774:	  150A	60 36			JZ	LIN1		;LINE LENGTHS EQUAL
 4775:	  150C	40 1F			JC	GTX		;SMALLER LINE
 4776:					;
 4777:				$EJECT

