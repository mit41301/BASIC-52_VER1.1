 1689:					;***************************************************************
 1690:					;
 1691:					;OUTPUT ROUTINES
 1692:					;
 1693:					;***************************************************************
 1694:					;
 1695:	  069B	D1 9D		CRLF2:	ACALL	CRLF		;DO TWO CRLF'S
 1696:					;
 1697:	  069D	7D 0D		CRLF:	MOV	R5,#CR		;LOAD THE CR
 1698:	  069F	F1 09			ACALL	TEROT		;CALL TERMINAL OUT
