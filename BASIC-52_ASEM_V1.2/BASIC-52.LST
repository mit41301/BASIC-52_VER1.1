 1708:	  06A7	E4		ROM_P:	CLR	A		;CLEAR A FOR LOOKUP
 1709:	  06A8	93			MOVC	A,@A+DPTR	;GET THE CHARACTER
 1710:	  06A9	C2 E7			CLR	ACC.7		;CLEAR MS BIT
