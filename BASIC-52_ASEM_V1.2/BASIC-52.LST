 4877:	  1575	1A			DEC	R2		;BUMP THE HIGH BYTE
 4878:	  1576	19			DEC	R1		;BUMP THE POINTER
 4879:	  1577	B9 FF F5		CJNE	R1,#0FFH,DEC_R	;SEE IF OVERFLOWED
 4880:	  157A	1B			DEC	R3		;CHANGE THE HIGH BYTE
